{
  "name": "nat-bridge",
  "version": "1.2.0",
  "description": "Peer-to-peer TCP/UDP tunnel over Hyperswarm. Bypass NAT/firewall without port forwarding.",
  "author": "Lawtro37",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/Lawtro37/nat-bridge",
  "repository": "github:Lawtro37/nat-bridge",
  "bin": "main.js",
  "scripts": {
    "launcher": "electron launcher/nat-bridge-launcher.js",
    "build:exe": "node scripts/icon_exe_safe.js",
    "build:launcher": "npx electron-packager launcher \"NAT-bridge Launcher\" --platform=win32 --arch=x64 --out build_temp --overwrite --icon=icons/icon.ico --prune=false",
    "package:all": "npm run build:exe && npm run build:launcher && node scripts/assemble_release.js"
  },
  "dependencies": {
    "hyperswarm": "^4.11.7",
    "multiplex": "^6.7.0",
    "pump": "^3.0.3",
    "blessed": "^0.1.81",
    "electron": "^41.1.1"
  },
  "devDependencies": {
    "@appthreat/caxa": "^3.0.0",
    "electron-packager": "^17.1.1",
    "rcedit": "^5.0.2"
  }
}
